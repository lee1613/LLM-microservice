# ── System & IDE ─────────────────────────────────────────────────
**/.DS_Store
**/__pycache__
**/*.pyc
**/.git
**/.gitignore
**/.vscode
**/.idea
**/.env

# ── Virtual environment ───────────────────────────────────────────
**/.venv

# ── Docker build artifacts ────────────────────────────────────────
**/.dockerignore
**/Dockerfile*
**/compose.y*ml
**/docker-compose*

# ── Dev / test scripts (not needed at runtime) ────────────────────
test_*.py
reset_db.py
check_db.py
check_registry.py
inspect_cases.py
test_import.py
notebooks/
b002_llm_output.json
# Exclude test output text files but NOT requirements.txt or setup_cpt_db.py
*_output.txt

# ── Kubernetes manifests (not needed inside image) ────────────────
k8s/

# ── Stale root-level DB (data/ contains the authoritative one) ────
claims.db

# NOTE: data/ directory IS included — it contains:
#   data/health-insurance-claim/synthetic data/database.db   (main DB)
#   data/health-insurance-claim/synthetic data/registry.db   (provider/physician)
#   data/cpt_reference.db                                    (CMS PFS CPT codes, built at image build time)
#   data/health-insurance-claim/medical bills/               (PDF documents)
